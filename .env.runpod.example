# Optional RunPod GPU job environment. Do not commit real values.
APP_ENV=cloud
DEPLOYMENT_MODE=cloud_gpu
COMPUTE_PROVIDER=runpod
MODEL_DEVICE=cuda
RUNPOD_DRY_RUN=true
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_URL=https://api.runpod.io/graphql
RUNPOD_TEMPLATE_ID=
RUNPOD_ENDPOINT_ID=
RUNPOD_GPU_TYPE=NVIDIA RTX A4000
RUNPOD_IMAGE=ghcr.io/pedroramos17/data-analysis:latest
RUNPOD_ALLOWED_IMAGES=ghcr.io/pedroramos17/data-analysis:latest
RUNPOD_MAX_RUNTIME_SECONDS=3600
RUNPOD_MAX_JOB_MINUTES=60
RUNPOD_IDLE_TIMEOUT_SECONDS=300
RUNPOD_MIN_GPU_MEMORY_GB=16
RUNPOD_MAX_HOURLY_COST=0.50
RUNPOD_MAX_DATASET_SIZE_GB=100
RUNPOD_ENABLE_SPOT=true
RUNPOD_ENABLE_PUBLIC_JUPYTER=false
RUNPOD_ENABLE_SSH=false
RUNPOD_TERMINATE_ON_COMPLETION=true
TRAIN_CONFIG_PATH=configs/train_gpu_runpod.yaml
TRAIN_COMMAND=python -m src.cli train run-windowed --config configs/train_gpu_runpod.yaml
RUNPOD_LOG_DIR=/workspace/logs
RUNPOD_ARTIFACT_DIR=/workspace/artifacts
RUNPOD_LOGS_URI=s3://example-bucket/data/lake/logs/runpod/fin_mamba
RUNPOD_ARTIFACTS_URI=s3://example-bucket/data/lake/models/fin_mamba/runpod
RUNPOD_METRICS_URI=s3://example-bucket/data/lake/metrics/runpod/fin_mamba
STORAGE_PROVIDER=s3
OBJECT_STORAGE_BUCKET=example-bucket
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=auto
REDACT_SECRETS=true
ALLOW_SHELL_COMMANDS=false
TERMINATE_REMOTE_ON_TIMEOUT=true
CLOUD_REQUIRE_BUDGET_APPROVAL=true
ALLOW_EXTERNAL_PAID_API_CALLS=false

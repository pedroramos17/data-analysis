DJANGO_SECRET_KEY=change-me-before-deploying
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example
APP_ENV=cloud
DEPLOYMENT_MODE=cloud_mvp
PORT=8000
WEB_CONCURRENCY=2

# Default cloud MVP uses the bundled Postgres container. For managed Postgres,
# replace DATABASE_URL and keep DB_MODE=postgres.
DB_MODE=postgres
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_change_me
DATABASE_URL=postgresql://quant:quant_change_me@postgres:5432/quant

# DuckDB remains a rebuildable local cache over Parquet/object storage.
OLAP_MODE=duckdb
DATA_LAKE_ROOT=/app/data/lake
DUCKDB_PATH=/app/data/lake/analytics.duckdb

# Use minio for one-VPS smoke tests, or set provider to r2/b2/s3 and point the
# endpoint/keys at Cloudflare R2, Backblaze B2, or another S3-compatible store.
STORAGE_PROVIDER=minio
OBJECT_STORAGE_BUCKET=quant-lake
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin_change_me
OBJECT_STORAGE_REGION=auto
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me

# Queue remains local by default. Set QUEUE_PROVIDER=redis and REDIS_URL when
# the optional redis service is enabled.
QUEUE_PROVIDER=local
REDIS_URL=redis://redis:6379/0
SCHEDULER_LIMIT=20
SCHEDULER_INTERVAL_SECONDS=3600

SECRETS_PROVIDER=env
MODEL_PROVIDER=local
MODEL_CACHE_DIR=/app/models
MODEL_REGISTRY_URI=/app/models
COMPUTE_PROVIDER=local
GPU_REQUIRED=false
GPU_BATCH_ENABLED=false
ORCHESTRATOR=local
RATE_LIMIT_PROVIDER=memory
MODEL_DEVICE=cpu
COST_MODE=minimum
SLIDING_WINDOW_STRATEGY=purged_walk_forward
SLIDING_WINDOW_TRAIN_SIZE=252
SLIDING_WINDOW_VALIDATION_SIZE=21
SLIDING_WINDOW_TEST_SIZE=21
SLIDING_WINDOW_STEP_SIZE=21
SLIDING_WINDOW_EMBARGO=1
SLIDING_WINDOW_HORIZON=1

# Optional cloud GPU dry-run profile. Set DEPLOYMENT_MODE=cloud_gpu and
# COMPUTE_PROVIDER=runpod for manifest-only planning; real launches require a
# future provider implementation plus RUNPOD_API_KEY.
RUNPOD_DRY_RUN=true
RUNPOD_API_KEY=
RUNPOD_GPU_TYPE=NVIDIA RTX A4000
RUNPOD_IMAGE=ghcr.io/pedroramos17/data-analysis:latest
RUNPOD_MAX_RUNTIME_SECONDS=3600
RUNPOD_MAX_JOB_MINUTES=60
RUNPOD_IDLE_TIMEOUT_SECONDS=300
RUNPOD_MAX_HOURLY_COST=0.50
RUNPOD_ENABLE_SPOT=true
RUNPOD_ENABLE_PUBLIC_JUPYTER=false
RUNPOD_ENABLE_SSH=false
RUNPOD_TERMINATE_ON_COMPLETION=true
AUTOSCALING_ENABLED=false
AUTOSCALING_MIN_WORKERS=0
AUTOSCALING_MAX_WORKERS=1
AUTOSCALING_SCALE_TO_ZERO=true
AUTOSCALING_IDLE_TIMEOUT_SECONDS=300
MAX_CONCURRENT_GPU_JOBS=1
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
API_AUTH_ENABLED=true
API_READ_ONLY_REQUIRES_AUTH=false
API_KEYS=
API_KEY_HASHES=
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
MAX_PRESIGNED_URL_EXPIRY_SECONDS=300
ALLOWED_STORAGE_PREFIXES=data/,datasets/,reports/,models/,exports/,logs/,metrics/
ALLOWED_CONFIG_ROOTS=configs
AUDIT_LOG_PATH=/app/data/lake/audit/security_audit.jsonl
EFFICIENCY_ENABLED=true
EFFICIENCY_SAMPLE_RATE=1.0
EFFICIENCY_RECORD_MEMORY=true
EFFICIENCY_RECORD_TIMING=true
REQUIRE_SECRETS_FOR_LAUNCH=true
ALLOW_SHELL_COMMANDS=false
REDACT_SECRETS=true
TERMINATE_REMOTE_ON_TIMEOUT=true

CLOUD_MONTHLY_BUDGET_USD=25.00
CLOUD_MAX_JOB_COST_USD=2.50
MAX_GPU_HOURLY_COST_USD=0.75
CLOUD_REQUIRE_BUDGET_APPROVAL=true
ENABLE_CLOUD_TESTS=false
ALLOW_EXTERNAL_PAID_API_CALLS=false

BROWSER_ENABLED=false
MONITOR_AUTOLOAD_CATALOGS=false
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_EMAIL=admin@example.local
DEV_ADMIN_PASSWORD=change-me-admin-password

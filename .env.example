OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=auto
QUEUE_PROVIDER=local
QUEUE_URL=
REDIS_URL=
SECRETS_PROVIDER=env
MODEL_PROVIDER=local
MODEL_CACHE_DIR=./models
MODEL_REGISTRY_URI=
COMPUTE_PROVIDER=local
GPU_REQUIRED=false
GPU_BATCH_ENABLED=false
ORCHESTRATOR=local
RATE_LIMIT_PROVIDER=memory
MODEL_DEVICE=cpu
COST_MODE=minimum
SLIDING_WINDOW_STRATEGY=purged_walk_forward
SLIDING_WINDOW_TRAIN_SIZE=252
SLIDING_WINDOW_VALIDATION_SIZE=21
SLIDING_WINDOW_TEST_SIZE=21
SLIDING_WINDOW_STEP_SIZE=21
SLIDING_WINDOW_EMBARGO=1
SLIDING_WINDOW_HORIZON=1
RUNPOD_DRY_RUN=true
RUNPOD_API_KEY=
RUNPOD_GPU_TYPE=NVIDIA RTX A4000
RUNPOD_IMAGE=ghcr.io/pedroramos17/data-analysis:latest
RUNPOD_MAX_RUNTIME_SECONDS=3600
RUNPOD_MAX_JOB_MINUTES=60
RUNPOD_IDLE_TIMEOUT_SECONDS=300
RUNPOD_MAX_HOURLY_COST=0.50
RUNPOD_ENABLE_SPOT=true
RUNPOD_ENABLE_PUBLIC_JUPYTER=false
RUNPOD_ENABLE_SSH=false
RUNPOD_TERMINATE_ON_COMPLETION=true
AUTOSCALING_ENABLED=false
AUTOSCALING_MIN_WORKERS=0
AUTOSCALING_MAX_WORKERS=1
AUTOSCALING_SCALE_TO_ZERO=true
AUTOSCALING_IDLE_TIMEOUT_SECONDS=300
MAX_CONCURRENT_GPU_JOBS=1
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
API_AUTH_ENABLED=true
API_READ_ONLY_REQUIRES_AUTH=false
API_KEYS=
API_KEY_HASHES=
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
MAX_PRESIGNED_URL_EXPIRY_SECONDS=300
ALLOWED_STORAGE_PREFIXES=data/,datasets/,reports/,models/,exports/,logs/,metrics/
ALLOWED_CONFIG_ROOTS=configs
AUDIT_LOG_PATH=./data/lake/audit/security_audit.jsonl
EFFICIENCY_ENABLED=true
EFFICIENCY_SAMPLE_RATE=1.0
EFFICIENCY_RECORD_MEMORY=true
EFFICIENCY_RECORD_TIMING=true
REQUIRE_SECRETS_FOR_LAUNCH=true
ALLOW_SHELL_COMMANDS=false
REDACT_SECRETS=true
TERMINATE_REMOTE_ON_TIMEOUT=true
CLOUD_MONTHLY_BUDGET_USD=25.00
CLOUD_MAX_JOB_COST_USD=2.50
MAX_GPU_HOURLY_COST_USD=0.75
CLOUD_REQUIRE_BUDGET_APPROVAL=true
ENABLE_CLOUD_TESTS=false
ALLOW_EXTERNAL_PAID_API_CALLS=false
COMPOSE_PROFILES=
INGESTION_DATA_DIR=./data
BROWSER_ENABLED=false
DEFAULT_HTTP_TIMEOUT=20
DEFAULT_RATE_LIMIT_PER_MINUTE=30
YOUTUBE_API_KEY=
EXPORT_PARQUET_COMPRESSION=zstd
USER_AGENT=data-analysis-bot/0.1 contact=your_email@example.com
MONITOR_AUTOLOAD_CATALOGS=false
# Development admin seed; when omitted under DJANGO_DEBUG=true, the command
# generates a one-time local password and prints it with --show-credentials.
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_EMAIL=admin@example.local
DEV_ADMIN_PASSWORD=

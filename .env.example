DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
APP_ENV=local
DEPLOYMENT_MODE=onprem
PORT=8000
WEB_CONCURRENCY=2
DB_MODE=sqlite
SQLITE_PATH=./db.sqlite3
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_SSLMODE=
OLAP_MODE=duckdb
STORAGE_PROVIDER=local
DATA_LAKE_ROOT=./data/lake
OBJECT_STORAGE_BUCKET=
